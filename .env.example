# Server
PORT=3000
BASE_URL=https://yourdomain.com

# Database (Supabase / PostgreSQL)
# Usa DATABASE_URL oppure le singole variabili DB_*
DATABASE_URL=postgresql://user:password@host:5432/database
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=

# Admin
ADMIN_TOKEN=inserisci_token_sicuro_qui

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email) — https://resend.com
RESEND_API_KEY=re_...
